# Production Environment Configuration
NODE_ENV=production
PORT=8080

# AI Configuration (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=https://caps360-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# JWT Configuration
# Generating a secure random secret for production usage
JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET
JWT_EXPIRES_IN=7d

# Database Configuration (Placeholder - will likely need to be updated after DB creation)
DB_HOST=caps360-pg.postgres.database.azure.com
DB_USER=capsadmin
DB_NAME=caps360
DB_SSL=true
DB_PASSWORD=YOUR_DB_PASSWORD
DATABASE_URL=postgresql://capsadmin:YOUR_DB_PASSWORD@caps360-pg.postgres.database.azure.com:5432/caps360?sslmode=require

# Business Logic
STUDY_HELP_PRICE=3900
STANDARD_PRICE=9900
PREMIUM_PRICE=14900
TRIAL_DURATION_DAYS=14
WELCOME_PREMIUM_DAYS=14

# Payment Configuration (Paystack)
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
VITE_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
